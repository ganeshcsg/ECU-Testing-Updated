# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Required for the ingestion pipeline and Alembic migrations.
DATABASE_URL=postgresql+psycopg2://ecu_user:ecusecretpassword@localhost:5432/ecu_testing

# ── Qdrant vector store ──────────────────────────────────────────────────────
# Leave QDRANT_PATH set to use local file-based storage (default, no server needed).
# Set QDRANT_HOST/PORT to use a remote Qdrant server instead.
QDRANT_PATH=./qdrant_data
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
QDRANT_COLLECTION=rag_ecu

# ── Embedding model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
# ST_TRUST_REMOTE_CODE=1       # Uncomment if using a model that requires it

# ── LLM (Ollama) ─────────────────────────────────────────────────────────────
# These are read by complete_rag_appV1.0.py at runtime.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
