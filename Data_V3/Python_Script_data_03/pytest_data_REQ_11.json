{
  "requirement": {
    "requirement_id": "GW-REQ-06",
    "description": "When any exterior lighting request or hazard condition is active, the gateway shall immediately transmit a consolidated exterior lighting state to the network.",

    "can_messages": [
      {
        "node": "BCM",
        "arbitration_id": "0x100",
        "message_name": "BCM_Status_1",
        "signals": [
          {
            "name": "Bdy_Hazard_Active",
            "start_bit": 0,
            "length": 1,
            "byte_order": "little_endian",
            "description": "Hazard switch state"
          }
        ]
      },
      {
        "node": "IC",
        "arbitration_id": "0x120",
        "message_name": "IC_Turn_Command",
        "signals": [
          {
            "name": "Turn_Command",
            "start_bit": 0,
            "length": 2,
            "description": "0=None, 1=Left, 2=Right"
          }
        ]
      },
      {
        "node": "GW",
        "arbitration_id": "0x384",
        "message_name": "GW_System_Overview",
        "dlc": 8,
        "signals": [
          {
            "name": "GWS_Indicator_State",
            "start_bit": 28,
            "length": 2,
            "byte_order": "little_endian",
            "description": "0=None, 1=Left, 2=Right, 3=Hazard"
          },
          {
            "name": "GWS_Any_Light_On",
            "start_bit": 30,
            "length": 1,
            "byte_order": "little_endian",
            "description": "1 = any exterior lamp active"
          }
        ]
      }
    ]
  },

  "test_cases": [

    {
      "test_case_id": "TC-GW-EXT-001",
      "test_objective": "Verify GW transmits HAZARD indicator state when hazard is active.",
      "preconditions": [
        "Ignition ON",
        "BCM hazard switch ON",
        "CAN monitoring active"
      ],
      "test_steps": [
        "Activate hazard",
        "Monitor GW_System_Overview (0x384)",
        "Decode GWS_Indicator_State"
      ],
      "expected_result": "GWS_Indicator_State = 3 (HAZARD)",
      "test_type": "Functional",
      "python_test_script": "def test_tc_gw_ext_001(can_bus):\n    msgs = collect_messages(can_bus, 0x384, 2)\n    assert msgs\n    for m in msgs:\n        assert decode_indicator_state(m) == 3"
    },

    {
      "test_case_id": "TC-GW-EXT-002",
      "test_objective": "Verify GW transmits LEFT indicator state when left turn is requested.",
      "preconditions": [
        "Ignition ON",
        "Left indicator active"
      ],
      "test_steps": [
        "Activate left indicator",
        "Monitor GW_System_Overview"
      ],
      "expected_result": "GWS_Indicator_State = 1 (LEFT)",
      "test_type": "Functional",
      "python_test_script": "def test_tc_gw_ext_002(can_bus):\n    msgs = collect_messages(can_bus, 0x384, 2)\n    assert msgs\n    for m in msgs:\n        assert decode_indicator_state(m) == 1"
    },

    {
      "test_case_id": "TC-GW-EXT-003",
      "test_objective": "Verify GW transmits RIGHT indicator state when right turn is requested.",
      "preconditions": [
        "Ignition ON",
        "Right indicator active"
      ],
      "test_steps": [
        "Activate right indicator",
        "Monitor GW_System_Overview"
      ],
      "expected_result": "GWS_Indicator_State = 2 (RIGHT)",
      "test_type": "Functional",
      "python_test_script": "def test_tc_gw_ext_003(can_bus):\n    msgs = collect_messages(can_bus, 0x384, 2)\n    assert msgs\n    for m in msgs:\n        assert decode_indicator_state(m) == 2"
    },

    {
      "test_case_id": "TC-GW-EXT-004",
      "test_objective": "Verify GW asserts Any_Light_On when parking lamp is active.",
      "preconditions": [
        "Ignition ON",
        "Parking lamp ON"
      ],
      "test_steps": [
        "Switch parking lamp ON",
        "Monitor GW_System_Overview",
        "Decode GWS_Any_Light_On"
      ],
      "expected_result": "GWS_Any_Light_On = 1",
      "test_type": "Functional",
      "python_test_script": "def test_tc_gw_ext_004(can_bus):\n    msgs = collect_messages(can_bus, 0x384, 2)\n    assert msgs\n    for m in msgs:\n        assert decode_any_light_on(m) == 1"
    },

    {
      "test_case_id": "TC-GW-EXT-005",
      "test_objective": "Verify GW asserts Any_Light_On when high beam is active.",
      "preconditions": [
        "Ignition ON",
        "High beam active"
      ],
      "test_steps": [
        "Activate high beam",
        "Monitor GW_System_Overview"
      ],
      "expected_result": "GWS_Any_Light_On = 1",
      "test_type": "Functional",
      "python_test_script": "def test_tc_gw_ext_005(can_bus):\n    msgs = collect_messages(can_bus, 0x384, 2)\n    assert msgs\n    for m in msgs:\n        assert decode_any_light_on(m) == 1"
    },

    {
      "test_case_id": "TC-GW-EXT-006",
      "test_objective": "Verify GW does not assert lighting state when no exterior lighting is active.",
      "preconditions": [
        "Ignition ON",
        "All lights OFF"
      ],
      "test_steps": [
        "Ensure all lighting OFF",
        "Monitor GW_System_Overview"
      ],
      "expected_result": "GWS_Any_Light_On = 0",
      "test_type": "Negative",
      "python_test_script": "def test_tc_gw_ext_006(can_bus):\n    msgs = collect_messages(can_bus, 0x384, 2)\n    assert msgs\n    for m in msgs:\n        assert decode_any_light_on(m) == 0"
    }
  ]
}
